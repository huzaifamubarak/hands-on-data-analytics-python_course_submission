import re

iso_count = 0
dm_count = 0
month_count = 0

admission_years = []

for record in records:
    fields = record.split(",")
    date = fields[8].strip()


    if re.findall(r'\d{4}-\d{2}-\d{2}', date):
        iso_count += 1

    if re.findall(r'\d{2}/\d{2}/\d{4}', date):
        dm_count += 1

    if re.findall(r'[A-Za-z]{3}\s+\d{1,2}\s+\d{4}', date):
        month_count += 1


    year = re.search(r'\d{4}', date)
    if year:
        admission_years.append(year.group())

print("ISO Format Count:", iso_count)
print("DD/MM/YYYY Format Count:", dm_count)
print("Month Name Format Count:", month_count)

print(f"\nAdmission Years:{admission_years}")



if len(set(admission_years)) == 1:
    print("\nAll records are from the same year:", admission_years[0])
else:
    print("\nRecords contain multiple years.")
