#phase 2  _________________________________________________
import re
clean_ids = []
for record in records:
    fields = record.split(",")

    pid = fields[0]
    clean_pid = re.sub(r"[^P0-9]","",pid)
    clean_ids.append(clean_pid)
    print(f'{clean_ids}')

clean_names = []
for record in records:
    fields = record.split(',')
    name = fields[1]

    clean_name = ' '.join(name.strip().split()).title()

    clean_names.append(clean_name)


print(f'\n\n{clean_names}')


clean_ages = []

for record in records:
    fields = record.split(",")
    age_str = fields[2]
    match = re.search(r"\d+", age_str)

    if match:
        clean_ages.append(int(match.group()))
    else:
        clean_ages.append(None)

print(f"Clean Ages: {clean_ages}")

missing = clean_ages.count(None)

print("\nMissing Ages:", missing)

ages = [age for age in clean_ages if age != None]

print("Youngest Patient:", min(ages))
print("Oldest Patient:", max(ages))

clean_genders = []

for record in records:
    fields = record.split(',')
    gender = fields[3].strip().lower()
    if gender.startswith('m'):
       clean_genders.append('M')
    else:
       clean_genders.append('F')
print(f'clean_genders:  {clean_genders}')

male_count = clean_genders.count('M')
female_count = clean_genders.count('F')

print(f'\nMales: {male_count} ')
print(f'Females: {female_count} ')

clean_temps = []
#99.0
for record in records:
    fields = record.split(",")
    temp = fields[7]
    unit = temp[-1]

    value = float(temp[:-1])

    if unit == "F":
        value = (value - 32) * 5 / 9

    value = round(value, 1)

    clean_temps.append(value)

